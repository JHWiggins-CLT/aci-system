# Local Claude Code config — contains machine/account-specific paths
.claude/

# Codex review scaffolding — transient artifacts, not part of the deliverable
.codex_audit_report.md
.codex_audit_prompt.txt

# Live deployment config — created on first run, deployment-local.
# The committed template is config/deployment.yaml.example.
config/deployment.yaml

# Per-run audit logs from the demo simulator. Content is deterministic; only the
# date in the filename changes, so every verify.sh run (which re-runs the
# simulator) spawns a fresh set of identical-content files. The already-committed
# ones remain as the audit-trail sample; a real production conversion adapter
# writes differently-named logs that are still tracked.
conversion/logs/*simulate_facility_data*.log

# Rendered exports — output of reports/render_html.py, not source. The committed
# capability is the renderer + reports/README.md + the export skill; the generated
# HTML is regenerable and lands here (outside the canonical data/ tree).
reports/*.html

# Python bytecode
__pycache__/
*.py[cod]

# OS cruft
.DS_Store
Thumbs.db
desktop.ini
